{
  "name": "packalert",
  "version": "0.1.3",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:scraper": "npm run dev --workspace=apps/scraper",
    "check-stock": "npm run start --workspace=apps/scraper"
  }
}
